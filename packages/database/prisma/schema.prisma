generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum WebsiteCrawlStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum GoogleBusinessProfileStatus {
  NOT_CONNECTED
  MANUAL_CONNECTED
  VERIFIED
}

enum SocialProfilePlatform {
  INSTAGRAM
  FACEBOOK
  TIKTOK
  LINKEDIN
  YOUTUBE
  X
  OTHER
}

enum SocialProfileStatus {
  MANUAL_CONNECTED
  VERIFIED
  DISCONNECTED
}

enum WebsiteAuditFindingCategory {
  TECHNICAL
  CONTENT
  SCHEMA
  LOCAL_SEO
  AI_VISIBILITY
}

enum WebsiteAuditFindingSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
}

enum WebsiteAuditFindingStatus {
  OPEN
  RESOLVED
  IGNORED
}

model Organization {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  memberships Membership[]
  businesses  Business[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Membership {
  id             String         @id @default(cuid())
  organizationId String
  userId         String
  role           MembershipRole @default(OWNER)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model Business {
  id                    String                   @id @default(cuid())
  organizationId        String
  name                  String
  slug                  String
  websiteUrl            String?
  category              String?
  country               String?
  city                  String?
  organization          Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  websites              Website[]
  googleBusinessProfile GoogleBusinessProfile?
  socialProfiles        SocialProfile[]
  visibilityScore       BusinessVisibilityScore?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model Website {
  id            String                @id @default(cuid())
  businessId    String
  url           String
  normalizedUrl String
  domain        String
  isPrimary     Boolean               @default(false)
  business      Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  crawls        WebsiteCrawl[]
  auditFindings WebsiteAuditFinding[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@unique([businessId, normalizedUrl])
  @@index([businessId])
  @@index([domain])
  @@index([businessId, isPrimary])
}

model WebsiteCrawl {
  id            String                @id @default(cuid())
  websiteId     String
  status        WebsiteCrawlStatus    @default(QUEUED)
  requestedAt   DateTime              @default(now())
  startedAt     DateTime?
  completedAt   DateTime?
  errorMessage  String?
  metadata      Json?
  website       Website               @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  auditFindings WebsiteAuditFinding[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([websiteId])
  @@index([status])
  @@index([websiteId, status])
  @@index([requestedAt])
}

model WebsiteAuditFinding {
  id             String                      @id @default(cuid())
  websiteId      String
  crawlId        String?
  category       WebsiteAuditFindingCategory
  severity       WebsiteAuditFindingSeverity
  status         WebsiteAuditFindingStatus   @default(OPEN)
  code           String
  title          String
  description    String
  recommendation String?
  evidence       Json?
  website        Website                     @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  crawl          WebsiteCrawl?               @relation(fields: [crawlId], references: [id], onDelete: SetNull)
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  @@unique([websiteId, code])
  @@index([websiteId])
  @@index([crawlId])
  @@index([status])
  @@index([severity])
  @@index([category])
  @@index([websiteId, status])
}

model GoogleBusinessProfile {
  id           String                      @id @default(cuid())
  businessId   String                      @unique
  profileUrl   String
  placeId      String?
  businessName String?
  address      String?
  city         String?
  country      String?
  phone        String?
  websiteUrl   String?
  status       GoogleBusinessProfileStatus @default(MANUAL_CONNECTED)
  business     Business                    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt

  @@index([status])
}

model SocialProfile {
  id          String                @id @default(cuid())
  businessId  String
  platform    SocialProfilePlatform
  profileUrl  String
  handle      String?
  displayName String?
  status      SocialProfileStatus   @default(MANUAL_CONNECTED)
  isPrimary   Boolean               @default(false)
  business    Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@unique([businessId, platform, profileUrl])
  @@index([businessId])
  @@index([businessId, platform])
  @@index([businessId, isPrimary])
  @@index([status])
}

model BusinessVisibilityScore {
  id           String   @id @default(cuid())
  businessId   String   @unique
  score        Int
  grade        String?
  summary      String?
  inputs       Json
  breakdown    Json
  calculatedAt DateTime
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([businessId])
  @@index([score])
  @@index([calculatedAt])
}
