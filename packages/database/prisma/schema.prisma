generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum WebsiteCrawlStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum GoogleBusinessProfileStatus {
  NOT_CONNECTED
  MANUAL_CONNECTED
  VERIFIED
}

enum SocialProfilePlatform {
  INSTAGRAM
  FACEBOOK
  TIKTOK
  LINKEDIN
  YOUTUBE
  X
  OTHER
}

enum SocialProfileStatus {
  MANUAL_CONNECTED
  VERIFIED
  DISCONNECTED
}

model Organization {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  memberships Membership[]
  businesses  Business[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Membership {
  id             String         @id @default(cuid())
  organizationId String
  userId         String
  role           MembershipRole @default(OWNER)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model Business {
  id                    String                 @id @default(cuid())
  organizationId        String
  name                  String
  slug                  String
  websiteUrl            String?
  category              String?
  country               String?
  city                  String?
  organization          Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  websites              Website[]
  googleBusinessProfile GoogleBusinessProfile?
  socialProfiles        SocialProfile[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model Website {
  id            String         @id @default(cuid())
  businessId    String
  url           String
  normalizedUrl String
  domain        String
  isPrimary     Boolean        @default(false)
  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  crawls        WebsiteCrawl[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([businessId, normalizedUrl])
  @@index([businessId])
  @@index([domain])
  @@index([businessId, isPrimary])
}

model WebsiteCrawl {
  id           String             @id @default(cuid())
  websiteId    String
  status       WebsiteCrawlStatus @default(QUEUED)
  requestedAt  DateTime           @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  errorMessage String?
  metadata     Json?
  website      Website            @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([websiteId])
  @@index([status])
  @@index([websiteId, status])
  @@index([requestedAt])
}

model GoogleBusinessProfile {
  id           String                      @id @default(cuid())
  businessId   String                      @unique
  profileUrl   String
  placeId      String?
  businessName String?
  address      String?
  city         String?
  country      String?
  phone        String?
  websiteUrl   String?
  status       GoogleBusinessProfileStatus @default(MANUAL_CONNECTED)
  business     Business                    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt

  @@index([status])
}

model SocialProfile {
  id          String                @id @default(cuid())
  businessId  String
  platform    SocialProfilePlatform
  profileUrl  String
  handle      String?
  displayName String?
  status      SocialProfileStatus   @default(MANUAL_CONNECTED)
  isPrimary   Boolean               @default(false)
  business    Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@unique([businessId, platform, profileUrl])
  @@index([businessId])
  @@index([businessId, platform])
  @@index([businessId, isPrimary])
  @@index([status])
}
