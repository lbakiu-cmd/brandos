generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum WebsiteCrawlStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

model Organization {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  memberships Membership[]
  businesses  Business[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Membership {
  id             String         @id @default(cuid())
  organizationId String
  userId         String
  role           MembershipRole @default(OWNER)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model Business {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  slug           String
  websiteUrl     String?
  category       String?
  country        String?
  city           String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  websites       Website[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model Website {
  id            String         @id @default(cuid())
  businessId    String
  url           String
  normalizedUrl String
  domain        String
  isPrimary     Boolean        @default(false)
  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  crawls        WebsiteCrawl[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([businessId, normalizedUrl])
  @@index([businessId])
  @@index([domain])
  @@index([businessId, isPrimary])
}

model WebsiteCrawl {
  id           String             @id @default(cuid())
  websiteId    String
  status       WebsiteCrawlStatus @default(QUEUED)
  requestedAt  DateTime           @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  errorMessage String?
  metadata     Json?
  website      Website            @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([websiteId])
  @@index([status])
  @@index([websiteId, status])
  @@index([requestedAt])
}
